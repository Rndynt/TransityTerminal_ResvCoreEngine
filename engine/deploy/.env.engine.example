# ─────────────────────────────────────────────
# Reservation Engine sidecar — per-operator env
# ─────────────────────────────────────────────
# Append these variables to the operator's existing TransityTerminal `.env`.
# Do NOT commit real values — keep one .env per operator outside the repo.
#
# Variable names match exactly what the engine binary reads (see
# engine/crates/engine-server/src/config.rs). Do not rename.
# ─────────────────────────────────────────────

# === Feature flag (read by TT) ===============================================
# false → TT uses the built-in Node atomicHold service. Engine container can
#         still run idle (it's cheap) or be omitted entirely from the compose
#         stack for small operators.
# true  → TT routes hold/release/confirm/cancel-seats to the engine sidecar.
RESERVATION_ENGINE_ENABLED=false

# === Engine connection (used by TT when flag is true) ========================
# The URL is fixed by the compose network — do not change unless you rename
# the service.
# RESERVATION_ENGINE_URL=http://engine:8000

# === Shared HMAC secret (read by BOTH TT and engine) =========================
# MUST match between TT and engine. Same env var name on both sides.
# Generate once per operator: `openssl rand -hex 32`
RESERVATION_ENGINE_HMAC_SECRET=replace-with-32-byte-hex-secret

# Allowed clock skew between TT and engine signatures, in seconds.
# Default 30s is conservative; raise only if you observe legitimate skew.
HMAC_SKEW_SECS=30

# === Engine container image ==================================================
# Image tag built from the engine repo. Use a semver tag in production
# (e.g. "v1.0.0") rather than "latest".
ENGINE_IMAGE_TAG=latest

# === Engine internals ========================================================
# Database URL the engine uses. Defaults to the same DATABASE_URL TT uses, so
# they share the seat_inventory and seat_holds tables. Override only if the
# engine should connect via a different pooler endpoint.
# ENGINE_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Log verbosity: error, warn, info, debug, trace
ENGINE_LOG_LEVEL=info

# Reaper sweep interval (seconds). 60 is the proven default.
REAPER_INTERVAL_SECS=60

# Connection pool sizes for the engine's sqlx pool.
DB_MIN_CONN=2
DB_MAX_CONN=10

# Max number of idempotency cache entries (LRU).
IDEMPOTENCY_MAX=10000

# Optional: Redis pub/sub URL for fan-out of `inventory.updated` /
# `holds.released` events. Leave empty to disable event publication.
# REDIS_URL=redis://redis:6379/0
